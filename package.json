{
  "name": "spring-app-commons",
  "packageManager": "yarn@4.12.0",
  "private": true,
  "license": "MIT",
  "devDependencies": {
    "@prettier/plugin-xml": "^3.4.2",
    "git-conventional-commits": "^2.8.0",
    "lint-staged": "^16.2.1",
    "prettier": "^3.6.2",
    "prettier-plugin-java": "^2.7.5",
    "prettier-plugin-properties": "^0.3.0",
    "prettier-plugin-toml": "^2.0.6",
    "rimraf": "^6.1.2"
  },
  "scripts": {
    "cleaner": "rimraf ./build */build ./module/*/build ./.gradle",
    "contributor": "pip install pyproject.toml --require-hashes && git config core.hooksPath .config/git/hooks",
    "merge": "yarn merge:kimi",
    "merge:copilot": "make merge ENGINE=copilot",
    "merge:junie": "make merge ENGINE=junie",
    "merge:kimi": "make merge ENGINE=kimi"
  }
}
